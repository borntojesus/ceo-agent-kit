---
import { getCollection } from 'astro:content';
import '../styles/global.css';

const entries = await getCollection('modules');

const modules = entries
  .map((e) => {
    const dir = e.id.split('/')[0];
    const body = e.body ?? '';
    const lines = body.split('\n');
    const titleLine = lines.find((l) => l.startsWith('# ')) ?? dir;
    const title = titleLine.replace(/^#\s*[\d]+\.\s*/, '').replace(/^#\s*/, '');
    const tIdx = lines.indexOf(titleLine);
    const summary =
      lines.slice(tIdx + 1).find((l) => l.trim().length > 0)?.trim() ?? '';
    return { slug: dir, num: dir.slice(0, 2), title, summary };
  })
  .sort((a, b) => a.slug.localeCompare(b.slug));
---

<html lang="uk">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>CEO Agent Kit: приватний AI-агент для керівника</title>
    <meta
      name="description"
      content="Чеклист із 14 модулів: розгорніть власного приватного AI-агента на своєму сервері. Для CEO, підприємців та C-level."
    />
    <link
      rel="icon"
      href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🤖</text></svg>"
    />
  </head>
  <body>
    <div class="wrap">
      <header class="site">
        <div class="kicker">CEO Agent Kit</div>
        <h1>Приватний AI-агент для керівника</h1>
        <p class="lead">
          Чеклист із 14 модулів. Ви проходите їх за порядком і отримуєте
          власного агента на власному сервері: він розбирає пошту, пише вам у
          Telegram, веде нотатки і будує ваші проєкти. Руками ви робите тільки
          оплати та підтвердження, решту налаштовує Claude Code за готовими
          промптами. Для CEO, підприємців та C-level.
        </p>
      </header>

      <div class="progress-box">
        <div class="progress-label">
          <span>Ваш прогрес</span>
          <span id="progress-count">0 з {modules.length}</span>
        </div>
        <div class="progress-bar"><div id="progress-fill"></div></div>
      </div>

      <ol class="modules">
        {
          modules.map((m) => (
            <li class="module-card" data-slug={m.slug}>
              <label class="m-check">
                <input
                  type="checkbox"
                  data-slug={m.slug}
                  aria-label={`Модуль ${m.num} виконано`}
                />
              </label>
              <div>
                <div class="m-num">Модуль {m.num}</div>
                <div class="m-title">
                  <a href={`/modules/${m.slug}/`}>{m.title}</a>
                </div>
                <div class="m-summary">{m.summary}</div>
              </div>
            </li>
          ))
        }
      </ol>

      <footer class="site">
        Промпти та інструкції:
        <a href="https://github.com/borntojesus/ceo-agent-kit">GitHub</a>.
        Агенти і скіли:
        <a href="https://github.com/borntojesus/claude-kit">claude-kit</a>.
        Автор: <a href="https://antonyuk.org">Дмитро Антонюк</a>. Потрібна
        допомога з налаштуванням:
        <a href="https://cal.antonyuk.org/dmytro/scoping-call">забронюйте дзвінок</a>.
      </footer>
    </div>

    <script>
      const KEY = 'ceo-agent-kit-progress';
      const read = (): Record<string, boolean> => {
        try {
          return JSON.parse(localStorage.getItem(KEY) ?? '{}');
        } catch {
          return {};
        }
      };
      const write = (s: Record<string, boolean>) =>
        localStorage.setItem(KEY, JSON.stringify(s));

      const boxes = Array.from(
        document.querySelectorAll<HTMLInputElement>('input[data-slug]'),
      );

      const render = () => {
        const state = read();
        let done = 0;
        for (const box of boxes) {
          const isDone = !!state[box.dataset.slug!];
          box.checked = isDone;
          box.closest('.module-card')!.classList.toggle('done', isDone);
          if (isDone) done++;
        }
        document.getElementById('progress-count')!.textContent =
          `${done} з ${boxes.length}`;
        document.getElementById('progress-fill')!.style.width =
          `${(done / boxes.length) * 100}%`;
      };

      for (const box of boxes) {
        box.addEventListener('change', () => {
          const state = read();
          state[box.dataset.slug!] = box.checked;
          write(state);
          render();
        });
      }
      render();
    </script>
  </body>
</html>
